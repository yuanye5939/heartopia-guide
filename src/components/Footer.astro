---
import { getLangFromPath, getUIStrings } from "../i18n/utils";
import { LANGUAGES } from "../i18n/ui";

const lang = getLangFromPath(Astro.url?.pathname || "/");
const t = getUIStrings(lang);
---

<footer class="border-t border-gray-800 mt-20 py-12">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="text-center md:text-left">
        <p class="text-gray-400 text-sm">
          &copy; {new Date().getFullYear()} Heartopia Guide. {t.footer.disclaimer}
        </p>
      </div>
      <div class="flex gap-6 text-sm text-gray-500">
        <a href={lang === "en" ? "/" : `/${lang}/`} class="hover:text-gray-300 transition-colors">Home</a>
        <span class="text-gray-700">|</span>
        <span>{t.footer.languages.replace("{count}", String(LANGUAGES.length))}</span>
      </div>
    </div>
  </div>
</footer>
