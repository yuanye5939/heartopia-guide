---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const guides = await getCollection("guide", ({ data }) => data.category === "beginner-guide" && data.lang === "en");
const guide = guides[0];
const { Content } = await guide.render();
---

<Layout
  title={guide.data.title}
  description={guide.data.description}
  ogType="article"
  schema={{
    "@type": "Article",
    headline: guide.data.title,
    description: guide.data.description,
    dateModified: guide.data.updatedAt?.toISOString(),
  }}
>
  <article class="max-w-4xl mx-auto px-4 py-12">
    <header class="mb-8">
      <p class="text-pink-400 text-sm font-medium mb-2">Beginner Guide</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-2">{guide.data.title}</h1>
      <p class="text-gray-400">{guide.data.description}</p>
    </header>
    <div class="prose prose-invert prose-pink max-w-none">
      <Content />
    </div>
  </article>
</Layout>
