---
import Layout from "../layouts/Layout.astro";
import HomeContent from "../components/HomeContent.astro";
import { getLangFromPath, getUIStrings } from "../i18n/utils";

const lang = getLangFromPath(Astro.url?.pathname || "/");
const t = getUIStrings(lang);
---

<Layout title="Home" description={t.siteDescription} ogType="website" lang={lang}>
  <HomeContent lang={lang} />
</Layout>
